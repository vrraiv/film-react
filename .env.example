# App title shown in the UI header
VITE_APP_TITLE=Film tracker

# Prefix used for browser localStorage. Change per environment/repo clone.
VITE_STORAGE_KEY_PREFIX=film-react

# Public base URL used for Supabase auth redirects and share links
VITE_PUBLIC_BASE_URL=https://your-site-name.netlify.app

# Supabase project configuration. Use the anon/public key only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
